.last_spark_version

# Java / Gradle build outputs
.gradle/
build/
bin/
out/
target/
*.class

# Java temporary and packaging artifacts
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# Logs and OS/editor files
*.log
.DS_Store
.bob/

# Spark/container runtime artifacts
containers/.gradle/
containers/_logs/
containers/_metastore/
containers/_warehouse/

# Keep containers/_apps directory, ignore its contents
containers/_apps/*
!containers/_apps/.gitkeep

# Ignore generated app artifacts in example projects
hello_java_app/.gradle/
hello_java_app/build/
hello_java_app/bin/
load_data_java_app/.gradle/
load_data_java_app/build/
load_data_java_app/bin/
